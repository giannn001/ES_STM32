/* Includes ------------------------------------------------------------------*/
#include "main.h"

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);

/* Private user code ---------------------------------------------------------*/
void UserButton_Callback(void);

/**
  * @brief  Entry point del programma
  */
int main(void)
{
  /* Inizializzazione base MCU */
  LL_APB2_GRP1_EnableClock(LL_APB2_GRP1_PERIPH_SYSCFG);
  LL_APB1_GRP1_EnableClock(LL_APB1_GRP1_PERIPH_PWR);

  SystemClock_Config();  // Configura il clock del sistema
  MX_GPIO_Init();        // Inizializza i GPIO

  /* Ciclo principale vuoto, tutto gestito tramite interrupt */
  while (1)
  {
  }
}

/**
  * @brief Configurazione del clock del sistema
  */
void SystemClock_Config(void)
{
  LL_FLASH_SetLatency(LL_FLASH_LATENCY_1);
  LL_RCC_HSI_Enable();
  while (!LL_RCC_HSI_IsReady());

  LL_RCC_HSI_SetCalibTrimming(64);
  LL_RCC_SetHSIDiv(LL_RCC_HSI_DIV_1);

  LL_RCC_SetAHBPrescaler(LL_RCC_HCLK_DIV_1);
  LL_RCC_SetSysClkSource(LL_RCC_SYS_CLKSOURCE_HSI);
  while (LL_RCC_GetSysClkSource() != LL_RCC_SYS_CLKSOURCE_STATUS_HSI);

  LL_RCC_SetAPB1Prescaler(LL_RCC_APB1_DIV_1);
  LL_Init1msTick(48000000);
  LL_SetSystemCoreClock(48000000);
}

/**
  * @brief Inizializzazione GPIO e EXTI
  */
static void MX_GPIO_Init(void)
{
  LL_GPIO_InitTypeDef GPIO_InitStruct = {0};
  LL_EXTI_InitTypeDef EXTI_InitStruct = {0};

  /* Abilita clock per le porte GPIO */
  LL_IOP_GRP1_EnableClock(LL_IOP_GRP1_PERIPH_GPIOC);
  LL_IOP_GRP1_EnableClock(LL_IOP_GRP1_PERIPH_GPIOA);

  /* Inizializza LED4 a OFF */
  LL_GPIO_ResetOutputPin(LED4_GPIO_Port, LED4_Pin);

  /* Configura il pulsante (PC13) come input senza pull-up/down */
  LL_GPIO_SetPinMode(GPIOC, LL_GPIO_PIN_13, LL_GPIO_MODE_INPUT);
  LL_GPIO_SetPinPull(GPIOC, LL_GPIO_PIN_13, LL_GPIO_PULL_NO);

  /* Configura EXTI per il pulsante */
  EXTI_InitStruct.Line_0_31 = LL_EXTI_LINE_13;
  EXTI_InitStruct.LineCommand = ENABLE;
  EXTI_InitStruct.Mode = LL_EXTI_MODE_IT;
  EXTI_InitStruct.Trigger = LL_EXTI_TRIGGER_FALLING;  // fronte di discesa
  LL_EXTI_Init(&EXTI_InitStruct);

  LL_EXTI_SetEXTISource(LL_EXTI_CONFIG_PORTC, LL_EXTI_CONFIG_LINE13);

  /* Configura LED4 come output push-pull */
  GPIO_InitStruct.Pin = LED4_Pin;
  GPIO_InitStruct.Mode = LL_GPIO_MODE_OUTPUT;
  GPIO_InitStruct.OutputType = LL_GPIO_OUTPUT_PUSHPULL;
  GPIO_InitStruct.Pull = LL_GPIO_PULL_NO;
  GPIO_InitStruct.Speed = LL_GPIO_SPEED_FREQ_LOW;
  LL_GPIO_Init(LED4_GPIO_Port, &GPIO_InitStruct);

  /* Abilita interrupt EXTI per il pulsante */
  NVIC_SetPriority(EXTI4_15_IRQn, 0);
  NVIC_EnableIRQ(EXTI4_15_IRQn);
}

/**
  * @brief Callback chiamata quando il pulsante viene premuto
  */
void UserButton_Callback(void)
{
  LL_GPIO_TogglePin(LED4_GPIO_Port, LED4_Pin);  // Toggle LED
}

/**
  * @brief Gestione errori
  */
void Error_Handler(void)
{
  __disable_irq();
  while (1)
  {
  }
}


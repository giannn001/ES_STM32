/* main.c - Driver LCD HD44780, modalità 4 bit, STM32G0 */

#include "main.h"

/* ── Macro GPIO ─────────────────────────────────────────────────── */
#define PIN_HIGH(name)  LL_GPIO_SetOutputPin(name##_GPIO_Port, name##_Pin)
#define PIN_LOW(name)   LL_GPIO_ResetOutputPin(name##_GPIO_Port, name##_Pin)
#define PIN_READ(name)  LL_GPIO_IsInputPinSet(name##_GPIO_Port, name##_Pin)

/* ── Costanti LCD ───────────────────────────────────────────────── */
#define LCD_CMD   0
#define LCD_DATA  1
#define LCD_ROW0  0x80
#define LCD_ROW1  0xC0

/* ── Prototipi ──────────────────────────────────────────────────── */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);

static void delay_us(uint32_t us);
static void lcd_pulse_enable(void);
static void lcd_write_half(uint8_t half);
static void lcd_write_byte(uint8_t byte, uint8_t type);
static void lcd_command(uint8_t cmd);
static void lcd_data(uint8_t ch);
static void lcd_setup(void);
static void lcd_goto(uint8_t row, uint8_t col);
static void lcd_puts(const char *s);

/* ── Implementazione ────────────────────────────────────────────── */

static void delay_us(uint32_t us)
{
    volatile uint32_t ticks = us * 3u;
    while (ticks--) __NOP();
}

static void lcd_pulse_enable(void)
{
    delay_us(1);
    PIN_HIGH(DISP_EN);
    delay_us(1);
    PIN_LOW(DISP_EN);
    delay_us(100);
}

/* Scrive i 4 bit bassi sul bus dati DB4-DB7 */
static void lcd_write_half(uint8_t half)
{
    (half & 0x1) ? PIN_HIGH(DISP_DB4) : PIN_LOW(DISP_DB4);
    (half & 0x2) ? PIN_HIGH(DISP_DB5) : PIN_LOW(DISP_DB5);
    (half & 0x4) ? PIN_HIGH(DISP_DB6) : PIN_LOW(DISP_DB6);
    (half & 0x8) ? PIN_HIGH(DISP_DB7) : PIN_LOW(DISP_DB7);
    lcd_pulse_enable();
}

/* Invia un byte completo: nibble alto poi nibble basso */
static void lcd_write_byte(uint8_t byte, uint8_t type)
{
    PIN_LOW(DISP_RW);
    (type == LCD_DATA) ? PIN_HIGH(DISP_RS) : PIN_LOW(DISP_RS);
    lcd_write_half(byte >> 4);    /* nibble alto  */
    lcd_write_half(byte & 0x0F); /* nibble basso */
}

static void lcd_command(uint8_t cmd)
{
    lcd_write_byte(cmd, LCD_CMD);
    /* Clear e Return Home richiedono più tempo */
    if (cmd <= 0x03)
        HAL_Delay(2);
}

static void lcd_data(uint8_t ch)
{
    lcd_write_byte(ch, LCD_DATA);
}

/* Sequenza di inizializzazione HD44780 in modalità 4 bit */
static void lcd_setup(void)
{
    PIN_LOW(DISP_EN);
    PIN_LOW(DISP_RS);
    PIN_LOW(DISP_RW);

    HAL_Delay(50);                          /* attesa power-on      */

    /* Tre reset in 8 bit (richiesti dal datasheet Hitachi) */
    lcd_write_half(0x03); HAL_Delay(5);
    lcd_write_half(0x03); delay_us(150);
    lcd_write_half(0x03); delay_us(150);

    lcd_write_half(0x02); delay_us(150);    /* passa a 4 bit        */

    lcd_command(0x28);                      /* 2 righe, font 5x8    */
    lcd_command(0x08);                      /* display off          */
    lcd_command(0x01); HAL_Delay(2);        /* clear display        */
    lcd_command(0x06);                      /* cursore incrementale */
    lcd_command(0x0C);                      /* display on           */
}

static void lcd_goto(uint8_t row, uint8_t col)
{
    uint8_t addr = (row == 0) ? (LCD_ROW0 + col) : (LCD_ROW1 + col);
    lcd_command(addr);
}

static void lcd_puts(const char *s)
{
    while (*s)
        lcd_data((uint8_t)*s++);
}

/* ── Main ───────────────────────────────────────────────────────── */

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();

    lcd_setup();

    lcd_goto(0, 0);
    lcd_puts("Gianluca");

    for (;;)
    {
        HAL_Delay(1000);
    }
}


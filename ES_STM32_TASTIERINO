      {
          /* accende LED di conferma */
          HAL_GPIO_WritePin(PIN_LED_GPIO_Port, PIN_LED_Pin, GPIO_PIN_SET);

          /* mostra valore in binario */
          mostraBinario(tasto);

          HAL_Delay(200);

          /* spegne LED di conferma */
          HAL_GPIO_WritePin(PIN_LED_GPIO_Port, PIN_LED_Pin, GPIO_PIN_RESET);
      }


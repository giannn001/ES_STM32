/* Mostra il numero sui LED in binario */
void mostraBinario(uint8_t valore)
{
    HAL_GPIO_WritePin(LED0_GPIO_Port, LED0_Pin, (valore & 1) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    HAL_GPIO_WritePin(LED1_GPIO_Port, LED1_Pin, (valore & 2) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    HAL_GPIO_WritePin(LED2_GPIO_Port, LED2_Pin, (valore & 4) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    HAL_GPIO_WritePin(LED3_GPIO_Port, LED3_Pin, (valore & 8) ? GPIO_PIN_SET : GPIO_PIN_RESET);
}

/* Scansione della tastiera */
int8_t leggiTasto(void)
{
    for(int r = 0; r < 4; r++)
    {
        /* spegne tutte le righe */
        HAL_GPIO_WritePin(GPIOB, R1_Pin | R2_Pin | R3_Pin | R4_Pin, GPIO_PIN_RESET);

        /* attiva una riga alla volta */
        if(r == 0) HAL_GPIO_WritePin(R1_GPIO_Port, R1_Pin, GPIO_PIN_SET);
        if(r == 1) HAL_GPIO_WritePin(R2_GPIO_Port, R2_Pin, GPIO_PIN_SET);
        if(r == 2) HAL_GPIO_WritePin(R3_GPIO_Port, R3_Pin, GPIO_PIN_SET);
        if(r == 3) HAL_GPIO_WritePin(R4_GPIO_Port, R4_Pin, GPIO_PIN_SET);

        HAL_Delay(5);

        /* controlla le colonne */
        if(HAL_GPIO_ReadPin(C1_GPIO_Port, C1_Pin) == GPIO_PIN_SET) return keyValues[r][0];
        if(HAL_GPIO_ReadPin(C2_GPIO_Port, C2_Pin) == GPIO_PIN_SET) return keyValues[r][1];
        if(HAL_GPIO_ReadPin(C3_GPIO_Port, C3_Pin) == GPIO_PIN_SET) return keyValues[r][2];
        if(HAL_GPIO_ReadPin(C4_GPIO_Port, C4_Pin) == GPIO_PIN_SET) return keyValues[r][3];
    }

    return -1;
}


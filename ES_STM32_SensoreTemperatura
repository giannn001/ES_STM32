/* USER CODE BEGIN PV */
/* Indirizzo I2C del sensore STTS751 (addr pin a GND → 0x4A, shifted a sinistra) */
#define SENSOR_I2C_ADDR     0x94

/* Registri interni del sensore */
#define REG_MSB_TEMP        0x00   // Byte intero della temperatura (con segno)
#define REG_LSB_TEMP        0x01   // Byte frazionario della temperatura
#define REG_SENSOR_CONF     0x03   // Registro di configurazione

static uint8_t raw_msb = 0;
static uint8_t raw_lsb = 0;
static float   temp_celsius = 0.0f;
/* USER CODE END PV */

/* Private variables ---------------------------------------------------------*/
I2C_HandleTypeDef  hi2c1;
UART_HandleTypeDef huart2;

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_I2C1_Init(void);
static void MX_USART2_UART_Init(void);

/* USER CODE BEGIN 0 */
/**
 * @brief Legge la temperatura dal sensore e aggiorna temp_celsius.
 * @retval 1 se la lettura ha avuto successo, 0 altrimenti.
 */
static uint8_t ReadTemperature(void)
{
    HAL_StatusTypeDef status;

    status = HAL_I2C_Mem_Read(&hi2c1, SENSOR_I2C_ADDR,
                               REG_MSB_TEMP, I2C_MEMADD_SIZE_8BIT,
                               &raw_msb, 1, 100);
    if (status != HAL_OK)
        return 0;

    HAL_I2C_Mem_Read(&hi2c1, SENSOR_I2C_ADDR,
                     REG_LSB_TEMP, I2C_MEMADD_SIZE_8BIT,
                     &raw_lsb, 1, 100);

    /*
     * Il byte MSB contiene la parte intera (signed, complemento a 2).
     * Il byte LSB codifica i decimali nei 4 bit più significativi:
     * ogni bit vale 0.0625 °C (risoluzione 12 bit totali).
     */
    int8_t  whole_part = (int8_t)raw_msb;
    uint8_t frac_nibble = raw_lsb >> 4;

    temp_celsius = (float)whole_part + (float)frac_nibble * 0.0625f;

    return 1;
}
/* USER CODE END 0 */

int main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  HAL_Init();

  /* USER CODE BEGIN Init */
  /* USER CODE END Init */

  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */
  /* USER CODE END 2 */

  /* USER CODE BEGIN 3 */
  while (1)
  {
      if (ReadTemperature())
      {
          /*
           * sprintf con float non è disponibile su tutti i target Cortex-M0
           * senza abilitare il supporto hardware. Si separano parte intera
           * e decimale per evitare dipendenze dalla libreria FP di printf.
           */
          char    msg[50];
          int32_t t_int  = (int32_t)temp_celsius;
          int32_t t_frac = (int32_t)((temp_celsius - (float)t_int) * 100.0f);
          if (t_frac < 0) t_frac = -t_frac;  // segno già in t_int

          sprintf(msg, "Temp: %ld.%02ld C\r\n", t_int, t_frac);
          HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), 1000);
      }

      HAL_Delay(1000);
  }
  /* USER CODE END 3 */
}

